# ============================================================
# PyDistance-Service Configuration
# Copy this file to `.env` and adjust values for your hardware.
# ============================================================

# --- Sensor physical parameters (CHG laser displacement sensor) ---
# Minimum measurable distance (mm)
D_MIN=50.0
# Maximum measurable distance (mm); CHG-1250 -> 2500, CHG-1400 -> 4000
D_MAX=2500.0
# Full-scale output voltage of the sensor (V)
V_MAX=10.0
# Voltage above this value indicates "no valid target" (datasheet: ~10.2V)
V_ERROR=10.1
# Voltage divider compensation ratio (real_v = measured_v * DIVIDER_RATIO)
DIVIDER_RATIO=1.682

# --- ADS1115 hardware configuration ---
# I2C address (0x48 default, 0x49/0x4A/0x4B by tying ADDR pin)
I2C_ADDRESS=0x48
# Channels to sample. JSON array of 0..3
ADS_DATA_RATE=250

# --- High-frequency sampling + 1-second window filtering ---
# Period of one round (all channels) in seconds. 0.02 -> ~50Hz/channel
SAMPLE_INTERVAL=0.02
# Filter window length in seconds (only samples within this window are used)
WINDOW_SECONDS=1.0
# Filter algorithm: "mean" | "median" | "trimmed_mean"
FILTER_METHOD=trimmed_mean
# Trim ratio for trimmed_mean (both ends), e.g. 0.2 -> drop top/bottom 20%
TRIM_RATIO=0.2
# Distance jump threshold (mm) to log as WARNING (anomaly detection)
ANOMALY_JUMP_MM=50.0

# --- Service configuration ---
HOST=0.0.0.0
PORT=8000
# WebSocket push interval in seconds (~10 updates/s at 0.1)
WS_PUSH_INTERVAL=0.1
LOG_LEVEL=INFO
LOG_FILE=logs/service.log
